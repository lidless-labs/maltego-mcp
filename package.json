{
  "name": "maltego-mcp",
  "version": "0.4.0",
  "description": "MCP server for authoring Maltego graph files and running primitive OSINT lookups.",
  "type": "module",
  "main": "dist/mcp-server.js",
  "bin": {
    "maltegoctrl": "dist/cli.js",
    "maltego-mcp": "dist/mcp-bin.js",
    "maltegoctl": "dist/cli.js"
  },
  "files": [
    "dist",
    "index.ts",
    "cli.ts",
    "mcp-bin.ts",
    "mcp-server.ts",
    "scripts",
    "src",
    "transforms",
    "openclaw.plugin.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.js mcp",
    "demo:basic": "npm run build && node dist/demo-basic.js",
    "test": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:all": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build",
    "setup:transforms": "node scripts/python-tool.mjs setup",
    "test:transforms": "node scripts/python-tool.mjs test",
    "build:mtz": "node scripts/python-tool.mjs build-mtz"
  },
  "license": "MIT",
  "author": "Solomon Neas <srneas@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lidless-labs/maltego-mcp.git"
  },
  "homepage": "https://github.com/lidless-labs/maltego-mcp#readme",
  "bugs": {
    "url": "https://github.com/lidless-labs/maltego-mcp/issues"
  },
  "keywords": [
    "mcp",
    "maltego",
    "osint",
    "graph",
    "model-context-protocol"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@sinclair/typebox": "^0.34.49",
    "fast-xml-parser": "^5.7.3",
    "jszip": "^3.10.1",
    "undici": "^6.27.0",
    "whois": "^2.14.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "tsup": "^8.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.4.27",
      "pluginSdkVersion": "2026.4.27"
    }
  },
  "overrides": {
    "esbuild": "0.28.1",
    "hono": "4.12.27"
  },
  "packageManager": "npm@10.9.7"
}
