{
  "name": "maltego-mcp",
  "version": "0.2.1",
  "description": "MCP server for authoring Maltego graph files and running primitive OSINT lookups.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "maltego-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:all": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build",
    "setup:transforms": "py -3 scripts/setup_venv.py",
    "test:transforms": "transforms/.venv/Scripts/python.exe -m pytest tests/transforms",
    "build:mtz": "py -3 scripts/build_mtz.py"
  },
  "license": "MIT",
  "author": "Solomon Neas <srneas@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/solomonneas/maltego-mcp.git"
  },
  "homepage": "https://github.com/solomonneas/maltego-mcp#readme",
  "bugs": {
    "url": "https://github.com/solomonneas/maltego-mcp/issues"
  },
  "keywords": [
    "mcp",
    "maltego",
    "osint",
    "graph",
    "model-context-protocol"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "jszip": "^3.10.1",
    "fast-xml-parser": "^4.3.0",
    "whois": "^2.14.0",
    "undici": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
