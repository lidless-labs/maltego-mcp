{
  "name": "maltego-mcp",
  "version": "0.2.0",
  "description": "MCP server for authoring Maltego graph files and running primitive OSINT lookups.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "maltego-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:all": "vitest run",
    "typecheck": "tsc --noEmit",
    "setup:transforms": "py -3 scripts/setup_venv.py",
    "test:transforms": "transforms/.venv/Scripts/python.exe -m pytest tests/transforms",
    "build:mtz": "py -3 scripts/build_mtz.py"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "jszip": "^3.10.1",
    "fast-xml-parser": "^4.3.0",
    "whois": "^2.14.0",
    "undici": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
